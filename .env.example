# Leadgen Pipeline — example env file.
# Copy to `.env` (prod) or `.env.dev` (local) and fill in real values.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/leadgen

# CORS
CORS_ORIGINS=http://localhost:5173

# Flask
FLASK_APP=api.app:create_app
FLASK_DEBUG=1

# Auth
JWT_SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
OAUTH_ENCRYPTION_KEY=

# LLM keys
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=leadgen

# Resend (email delivery)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# While DNS for loserscirque.cz is unverified, sandbox=true forces sender to onboarding@resend.dev
RESEND_SANDBOX_MODE=true

# ---------------------------------------------------------------------------
# Microsite integration (UA microsite — ua-microsite repo)
# ---------------------------------------------------------------------------
# URL of the ua-microsite for campaign invite link generation + partner token
# reconciliation. Default: https://demo.visionvolve.com (staging), or
# https://booking.loserscirque.cz (prod once DNS is live).
UA_MICROSITE_URL=https://demo.visionvolve.com

# IMPORTANT: this value must match LEADGEN_SITE_EVENTS_API_KEY on the
# ua-microsite side (src/lib/leadgen-client.ts reads it as the X-API-Key
# header when POSTing to /api/tracking/microsite-event). Rotating the key
# requires updating both repos simultaneously.
UA_INVITE_API_KEY=change-me-to-a-secure-random-string

# ---------------------------------------------------------------------------
# EventFest campaign defaults (scripts/provision_eventfest_campaign.py)
# ---------------------------------------------------------------------------
UA_MAILING_FROM_EMAIL=hana@loserscirque.cz
UA_MAILING_FROM_NAME=Hanka | Losers Cirque Company
UA_MAILING_REPLY_TO=hana@unitedarts.cz
