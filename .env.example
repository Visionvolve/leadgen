# Leadgen Pipeline — example env file.
# Copy to `.env` (prod) or `.env.dev` (local) and fill in real values.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/leadgen

# CORS
CORS_ORIGINS=http://localhost:5173

# Flask
FLASK_APP=api.app:create_app
FLASK_DEBUG=1

# Auth
JWT_SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
OAUTH_ENCRYPTION_KEY=

# LLM keys
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=leadgen

# Resend (email delivery)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
# While DNS for loserscirque.cz is unverified, sandbox=true forces sender to onboarding@resend.dev
RESEND_SANDBOX_MODE=true

# ---------------------------------------------------------------------------
# Microsite integration (UA microsite — ua-microsite repo)
# ---------------------------------------------------------------------------
# URL of the ua-microsite for campaign invite link generation + partner token
# reconciliation. Default: https://demo.visionvolve.com (staging), or
# https://booking.loserscirque.cz (prod once DNS is live).
UA_MICROSITE_URL=https://demo.visionvolve.com

# IMPORTANT: this value must match LEADGEN_SITE_EVENTS_API_KEY on the
# ua-microsite side (src/lib/leadgen-client.ts reads it as the X-API-Key
# header when POSTing to /api/tracking/microsite-event). Rotating the key
# requires updating both repos simultaneously.
UA_INVITE_API_KEY=change-me-to-a-secure-random-string

# ---------------------------------------------------------------------------
# EventFest campaign defaults (scripts/provision_eventfest_campaign.py)
# ---------------------------------------------------------------------------
UA_MAILING_FROM_EMAIL=hana@loserscirque.cz
UA_MAILING_FROM_NAME=Hanka | Losers Cirque Company
UA_MAILING_REPLY_TO=hana@unitedarts.cz

# ---------------------------------------------------------------------------
# PostHog — campaign analytics microsite metrics (BL-1035)
# ---------------------------------------------------------------------------
# Backend reads microsite events (visits, CTA clicks, form submits, time on
# page) from PostHog's Query API and joins them with our DB email telemetry
# to render the Campaign Analytics surface (Echo + OutreachTab). See
# docs/specs/campaign-analytics.md §5.5.
#
# Region = US. Account was created in the US region; EU migration is a
# separate future effort. Override POSTHOG_HOST to point at an EU project.
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=

# Public project key — ships to the browser via posthog-js in the
# ua-microsite bundle. PUBLIC exposure is acceptable (by design) but the
# key still belongs in env / 1Password, not in git.
POSTHOG_PROJECT_API_KEY=phc_change_me

# Personal API key — SECRET, backend-only. Used to authenticate to the
# Query API. NEVER expose to frontend. NEVER log. Provision in PostHog
# (Settings -> Personal API Keys -> Create) and store in 1Password
# `visionvolve-prod` vault.
POSTHOG_PERSONAL_API_KEY=phx_change_me

# ---------------------------------------------------------------------------
# AITransformers contact sync (BL-1200)
# ---------------------------------------------------------------------------
# The daily sync (cron + `flask sync-aitransformers`) pulls authenticated
# AITransformers users out of the cases-api `GET /admin/leads-export`
# endpoint and lands them in the Visionvolve namespace as contacts tagged
# `AITransformers`. See:
#   docs/superpowers/specs/2026-05-13-aitransformers-contact-sync-design.md
#   api/jobs/aitransformers_contact_sync.py

# Base URL for the cases-api admin endpoint. Override in staging.
AITRANSFORMERS_API_URL=https://aitransformers.eu/api

# Service token granted by cases-api admin middleware. SECRET — store in
# 1Password (visionvolve-prod vault) and inject via prod `.env` /
# GitHub Actions secrets. Sync refuses to run when this is unset.
AITRANSFORMERS_ADMIN_TOKEN=change-me-to-the-aitransformers-admin-token

# Optional overrides (defaults shown):
# LEADGEN_AITRANSFORMERS_TENANT_SLUG=visionvolve
# LEADGEN_AITRANSFORMERS_BATCH_SIZE=200
# LEADGEN_AITRANSFORMERS_TAG_NAME=AITransformers
